---
import { Globe, AtSign, FileUser } from "@lucide/astro";
import World from "./sections/World.astro";

import links from "../data/links.json";
import type { LinkTreeData } from "../types";

const data = links as LinkTreeData;
const BASE_URL = import.meta.env.BASE_URL;

const githubIcon = `${BASE_URL}icons/github.svg`;
const linkedinIcon = `${BASE_URL}icons/linkedin.svg`;
---

<section class="relative min-h-dvh overflow-hidden bg-white text-black font-sans">
  <div class="pointer-events-none absolute inset-0 z-0 h-full w-full">
    <World />
  </div>

  <div class="relative z-10 flex min-h-dvh items-center justify-center px-0 py-8 sm:px-2 sm:py-12">
    
    <div class="flex w-[80%] flex-col items-stretch text-center sm:max-w-md">
      
      <h1 class="w-full text-6xl font-bold tracking-tight sm:text-5xl">
        {data.title}
      </h1>

      <p class="mt-4 w-full text-base font-semibold uppercase tracking-[0.28em] sm:text-base sm:tracking-[0.3em]">
        {data.subtitle}
      </p>

      <div
        class="mt-10 mb-4 flex max-h-[55vh] w-full flex-col items-stretch gap-5 overflow-y-auto pr-1 scrollbar-hide sm:mt-12 sm:max-h-[60vh] sm:gap-4"
      >
        {
          data.items.map((item) => (
            <a
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
              class="flex min-h-16 w-full items-center justify-center gap-3 rounded-2xl bg-lime-400 px-6 py-4 text-base font-bold text-black shadow-sm transition duration-300 hover:scale-[1.03] hover:bg-lime-300 sm:min-h-14 sm:px-6 sm:py-4 sm:text-lg"
            >
              {item.icon === "globe" && (
                <Globe size={26} stroke-width={2.5} />
              )}

              {item.icon === "github" && (
                <img
                  src={githubIcon}
                  alt="GitHub"
                  class="h-6 w-6 sm:h-7 sm:w-7"
                />
              )}

              {item.icon === "linkedin" && (
                <img
                  src={linkedinIcon}
                  alt="LinkedIn"
                  class="h-6 w-6 sm:h-7 sm:w-7"
                />
              )}

              {item.icon === "email" && (
                <AtSign size={26} stroke-width={2.5} />
              )}

              {item.icon === "cv" && (
                <FileUser size={26} stroke-width={2.5} />
              )}

              <span>{item.label}</span>
            </a>
          ))
        }
      </div>

    </div>
  </div>
</section>

<style is:global>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>