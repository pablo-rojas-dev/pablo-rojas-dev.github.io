---
import { ArrowUpRight, ChevronLeft, ChevronRight } from "@lucide/astro";
import ShowMoreButton from "../ui/ShowMoreButton.astro";
import type { ProjectsData } from "../../types"

const { data } = Astro.props as {
  data: ProjectsData;
}

const asset = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
---

<section id="projects" class="w-full py-16">
  <h2 class="mt-12 mb-12 text-center text-5xl font-bold">
    {data.title}
  </h2>

  <div class="show-more-container mx-auto flex max-w-6xl flex-col gap-12 px-4"
    data-show-more
    data-visible="2">
    {
      data.items.map((project) => (
        <article
          class="show-more-card project-card group mx-auto grid w-full sm:w-[75%] md:w-full max-w-5xl cursor-pointer gap-8 rounded-2xl p-6 text-center md:grid-cols-2 md:items-center md:text-left"
          data-url={project.demoUrl}
        >
          <div class="relative overflow-hidden rounded-xl">
            <div class="carousel flex overflow-hidden scroll-smooth">
              {project.images.map((image, index) => (
                <img
                  src={asset(image)}
                  alt={`${project.title} imagen ${index + 1}`}
                  class="carousel-item h-64 w-full flex-shrink-0 object-cover md:h-72"
                  loading="lazy"
                />
              ))}
            </div>

            <button
              type="button"
              class="carousel-prev absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/80 px-3 py-2 text-2xl font-bold shadow transition hover:bg-lime-400"
            >
              <ChevronLeft />
            </button>

            <button
              type="button"
              class="carousel-next absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/80 px-3 py-2 text-2xl font-bold shadow transition hover:bg-lime-400"
            >
              <ChevronRight/>
            </button>

            <div class="carousel-dots absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2">
              {project.images.map(() => (
                <button
                  type="button"
                  class="carousel-dot h-2 w-2 rounded-full transition"
                />
              ))}
            </div>
          </div>

          <div class="flex flex-col items-center md:items-start">
            <div class="mb-5 flex w-full flex-col items-center justify-center gap-4 md:flex-row md:justify-between">
              <div class="inline-flex items-center gap-2 text-xl font-bold">
                {project.title}
                <ArrowUpRight class="arrow h-5 w-5 transition-transform duration-300" />
              </div>

              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="stop-click group inline-flex items-center gap-2 rounded-full border border-black px-4 py-1.5 text-sm font-semibold text-black transition hover:bg-black hover:text-white"
              >
                <span class="icon github"></span>
                GitHub
              </a>
            </div>

            <p class="mb-6 max-w-xl text-base leading-relaxed text-neutral-700">
              {project.description}
            </p>

            <div class="flex flex-wrap justify-center gap-3 md:justify-start">
              {project.tags.map((tag) => (
                <span class="rounded-full border border-black px-4 py-1 text-sm font-medium">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
  
  <ShowMoreButton />
  
</section>

<script>
  /* CARD COMPLETA CLICKEABLE */
  document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
    card.addEventListener("click", () => {
      const url = card.dataset.url;
      if (url) {
        window.open(url, "_blank");
      }
    });
  });

  /* EVITAR QUE BOTONES INTERNOS DISPARAN CARD */
  document.querySelectorAll<HTMLElement>(".stop-click, .carousel-prev, .carousel-next, .carousel-dot")
    .forEach((element) => {
      element.addEventListener("click", (e) => e.stopPropagation());
    });

  /* CAROUSEL */
  document.querySelectorAll<HTMLElement>(".carousel").forEach((carousel) => {
    const wrapper = carousel.parentElement;
    const items = carousel.querySelectorAll(".carousel-item");
    const prevBtn = wrapper?.querySelector(".carousel-prev");
    const nextBtn = wrapper?.querySelector(".carousel-next");
    const dots = wrapper?.querySelectorAll(".carousel-dot");

    let currentIndex = 0;

    function updateCarousel() {
      carousel.scrollTo({
        left: carousel.clientWidth * currentIndex,
        behavior: "smooth",
      });

      dots?.forEach((dot, index) => {
        dot.classList.toggle("bg-lime-400", index === currentIndex);
        dot.classList.toggle("bg-gray-500", index !== currentIndex);
      });
    }

    nextBtn?.addEventListener("click", () => {
      currentIndex = (currentIndex + 1) % items.length;
      updateCarousel();
    });

    prevBtn?.addEventListener("click", () => {
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      updateCarousel();
    });

    dots?.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        updateCarousel();
      });
    });

    updateCarousel();
  });
</script>

<style>
  .project-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .project-card:hover {
    transform: scale(1.04);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);
  }

  .project-card:hover .arrow {
    transform: translateY(-4px) translateX(4px);
  }

  .carousel {
    scrollbar-width: none;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }
</style>