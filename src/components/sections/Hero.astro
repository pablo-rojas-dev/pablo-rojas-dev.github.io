---
import { CircleChevronDown, AtSign } from "@lucide/astro";
import LanguageToggle from "../../components/ui/LanguageToggle.astro";

const BASE_URL = import.meta.env.BASE_URL;
const { lang = "en" } = Astro.props;

const isSpanish = lang === "es";
const cvUrl = isSpanish
  ? `${BASE_URL}docs/cv-es.pdf`
  : `${BASE_URL}docs/cv-en.pdf`;

const mailToastMessage = isSpanish
  ? "Correo copiado"
  : "Email copied";

const githubIcon = `${BASE_URL}icons/github.svg`;
const linkedinIcon = `${BASE_URL}icons/linkedin.svg`;
---

<section
  id="hero"
  class="relative h-dvh bg-white text-black overflow-hidden"
>
  <div class="relative h-full flex items-center justify-center px-6">
    <div class="flex flex-col items-center text-center">

      <h1
        class="hero-item text-7xl text-shadow-2xs md:text-7xl font-bold tracking-tight"
        style="--delay: 0s;"
      >
        Pablo Rojas
      </h1>

      <p
        class="hero-item mt-4 text-lg md:text-2xl tracking-[0.35em] text-black"
        style="--delay: 0.15s;"
      >
        BACKEND DEVELOPER
      </p>

      <div
        class="hero-item mt-10 flex items-center gap-5"
        style="--delay: 0.3s;"
      >
        <a
          href="https://github.com/pablo-rojas-dev"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-400 transition-transform duration-300 hover:scale-110"
        >
          <img src={githubIcon} alt="GitHub" class="h-7 w-7" />
        </a>

        <a
          href="https://www.linkedin.com/in/pablo-rojas-dev"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-400 transition-transform duration-300 hover:scale-110"
        >
          <img src={linkedinIcon} alt="LinkedIn" class="h-7 w-7" />
        </a>

        <a
          href={cvUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-400 transition-transform duration-300 hover:scale-110 text-2xl font-bold"
        >
          CV
        </a>

        <button
          type="button"
          data-copy-email
          data-email="pablorojas.job@gmail.com"
          data-toast="mail-toast"
          class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-400 transition-transform duration-300 hover:scale-110"
        >
          <AtSign stroke-width={3} />
        </button>
      </div>

      <div
        class="hero-item mt-10"
        style="--delay: 0.45s;"
      >
        <LanguageToggle />
      </div>

      <div
        class="hero-item mt-20"
        style="--delay: 0.6s;"
      >
        <button
          id="scroll-down-button"
          class="animate-float"
        >
          <CircleChevronDown size={48} stroke-width={1.5} />
        </button>
      </div>

    </div>
  </div>

  <div
    id="mail-toast"
    class="fixed left-1/2 top-1/10 -translate-x-1/2 -translate-y-1/2 rounded-full bg-lime-400 px-6 py-3 text-sm font-semibold text-black opacity-0 pointer-events-none transition-opacity duration-300 z-50 text-center"
  >
    {mailToastMessage}
  </div>
</section>

<style>
  .hero-item {
    opacity: 0;
    transform: translateY(40px);
    animation: fadeUp 1s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  document
    .getElementById("scroll-down-button")
    ?.addEventListener("click", () => {
      window.scrollTo({
        top: window.innerHeight,
        behavior: "smooth"
      });
    });
</script>