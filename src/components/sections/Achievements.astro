---
import { ArrowUpRight } from "@lucide/astro";
import type { AchievementsData } from "../../types";

const { data } = Astro.props as {
  data: AchievementsData;
};

const asset = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
---

<section id="achievements" class="w-full py-16">
  <h2 class="mt-12 mb-10 text-center text-5xl font-bold">
    {data.title}
  </h2>

  <div class="mx-auto max-w-6xl px-4">
    <div class="relative overflow-visible py-8">
      <div class="achievements-carousel flex overflow-x-auto scroll-smooth px-4 py-6">
        {
          data.items.map((achievement, index) => (
            <article
              class="achievement-card w-[85%] shrink-0 px-4 transition-transform duration-300 hover:z-10 hover:scale-105 sm:w-[70%] md:w-1/2"
              data-index={index}
            >
              <div class="flex h-full flex-col items-center rounded-2xl border border-black/10 p-4 text-center shadow-sm">
                <img
                  src={asset(achievement.image)}
                  alt={achievement.title}
                  class="mb-4 h-48 w-full rounded-xl object-cover"
                  loading="lazy"
                />

                <div class="flex flex-1 flex-col items-center justify-center space-y-3">
                  <h3 class="text-xl font-bold">{achievement.title}</h3>

                  <a
                    href={achievement.organizationUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="organization-link inline-flex items-center justify-center gap-1 font-medium hover:underline"
                  >
                    {achievement.organization}
                    <ArrowUpRight class="organization-arrow h-4 w-4 transition-transform duration-300" />
                  </a>

                  <p class="text-sm font-semibold">{achievement.date}</p>

                  <p
                    class="description-content text-sm leading-relaxed"
                    set:html={achievement.description}
                  />

                  <div class="flex flex-wrap justify-center gap-2 pt-2">
                    {
                      achievement.tags.map((tag) => (
                        <span class="rounded-full border border-black/10 px-3 py-1 text-xs font-medium">
                          {tag}
                        </span>
                      ))
                    }
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .achievements-carousel {
    scrollbar-width: none;
  }

  .achievements-carousel::-webkit-scrollbar {
    display: none;
  }

  .organization-link:hover .organization-arrow {
    transform: translateY(-3px) translateX(3px);
  }

  .description-content :global(a) {
    font-weight: 600;
    text-decoration: underline;
  }
</style>