---
import { ChevronLeft, ChevronRight, ArrowUpRight } from "@lucide/astro";
import type { AchievementsData } from "../../types";

const { data } = Astro.props as {
  data: AchievementsData;
};
---

<section id="achievements" class="w-full py-16">
  <h2 class="mt-12 mb-10 text-center text-5xl font-bold">
    {data.title}
  </h2>

  <div class="mx-auto max-w-6xl px-4">
    <div class="relative overflow-visible py-8">
        <div
            class="achievements-carousel flex overflow-x-auto scroll-smooth px-4 py-6"
            data-carousel
        >
        {
          data.items.map((achievement, index) => (
            <article
                class="achievement-card w-[85%] shrink-0 px-4 transition-transform duration-300 hover:z-10 hover:scale-105 sm:w-[70%] md:w-1/3"
                data-index={index}
            >
              <div class="flex h-full flex-col items-center rounded-2xl border border-black/10 p-4 text-center shadow-sm">
                <img
                  src={`${import.meta.env.BASE_URL}${achievement.image.replace(/^\/+/, "")}`}
                  alt={achievement.title}
                  class="mb-4 h-48 w-full rounded-xl object-cover"
                  loading="lazy"
                />

                <div class="flex flex-1 flex-col items-center justify-center space-y-3">
                  <h3 class="text-xl font-bold">{achievement.title}</h3>

                  <a
                    href={achievement.organizationUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="organization-link inline-flex items-center justify-center gap-1 font-medium hover:underline"
                  >
                    {achievement.organization}
                    <ArrowUpRight class="organization-arrow h-4 w-4 transition-transform duration-300" />
                  </a>

                  <p class="text-sm font-semibold">{achievement.date}</p>

                  <p class="text-sm leading-relaxed">
                    {achievement.description}
                  </p>

                  <div class="flex flex-wrap justify-center gap-2 pt-2">
                    {
                      achievement.tags.map((tag) => (
                        <span class="rounded-full border border-black/10 px-3 py-1 text-xs font-medium">
                          {tag}
                        </span>
                      ))
                    }
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mt-8 flex justify-center gap-4">
      <button
        type="button"
        class="carousel-prev rounded-full shadow-xl p-3 transition hover:scale-105 hover:bg-lime-400"
        aria-label="Previous achievement"
      >
        <ChevronLeft class="h-6 w-6" stroke-width={3} />
      </button>

      <button
        type="button"
        class="carousel-next rounded-full shadow-xl p-3 transition hover:scale-105 hover:bg-lime-400"
        aria-label="Next achievement"
      >
        <ChevronRight class="h-6 w-6" stroke-width={3} />
      </button>
    </div>
  </div>
</section>

<script>
    const achievementsSection = document.querySelector<HTMLElement>("#achievements");

    const carousel =
        achievementsSection?.querySelector<HTMLElement>("[data-carousel]");

    const cards =
        achievementsSection?.querySelectorAll<HTMLElement>(".achievement-card") ?? [];

    const prevButton =
        achievementsSection?.querySelector<HTMLButtonElement>(".carousel-prev");

    const nextButton =
        achievementsSection?.querySelector<HTMLButtonElement>(".carousel-next");

    const getCardWidth = () => cards[0]?.offsetWidth ?? 0;

    prevButton?.addEventListener("click", () => {
        carousel?.scrollBy({
        left: -getCardWidth(),
        behavior: "smooth",
        });
    });

    nextButton?.addEventListener("click", () => {
        carousel?.scrollBy({
        left: getCardWidth(),
        behavior: "smooth",
        });
    });
</script>

<style>
  .achievements-carousel {
    scrollbar-width: none;
  }

  .achievements-carousel::-webkit-scrollbar {
    display: none;
  }

  .organization-link:hover .organization-arrow {
    transform: translateY(-3px) translateX(3px);
  }
</style>