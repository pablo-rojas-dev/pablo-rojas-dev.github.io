---
import { CircleArrowUp } from "@lucide/astro";
---

<button
  id="scroll-to-top-button"
  type="button"
  class="fixed bottom-6 right-6 z-50 hidden rounded-full bg-lime-400 p-3 text-black shadow-lg transition hover:scale-110"
  aria-label="Volver al inicio"
>
  <CircleArrowUp class="h-8 w-8" stroke-width={1.8} />
</button>

<script>
  const button = document.getElementById("scroll-to-top-button");
  const hero = document.getElementById("hero");
  const about = document.getElementById("about");
  const footer = document.querySelector("footer");

  const updateButtonVisibility = () => {
    if (!button || !hero || !about) return;

    const aboutTop = about.getBoundingClientRect().top;
    const footerTop = footer?.getBoundingClientRect().top;

    const isAfterAbout = aboutTop <= window.innerHeight * 0.7;
    const isInFooter = footerTop !== undefined && footerTop <= window.innerHeight;

    button.classList.toggle("hidden", !isAfterAbout || isInFooter);
  };

  button?.addEventListener("click", () => {
    hero?.scrollIntoView({
      behavior: "smooth",
      block: "start",
    });
  });

  window.addEventListener("scroll", updateButtonVisibility);
  window.addEventListener("resize", updateButtonVisibility);
  window.addEventListener("load", updateButtonVisibility);

  updateButtonVisibility();
</script>