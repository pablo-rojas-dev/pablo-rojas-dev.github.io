---
const BASE_URL = import.meta.env.BASE_URL;

const pathname = Astro.url.pathname;

const normalizedPath = pathname.replace(BASE_URL, "/");

const isSpanish = normalizedPath.startsWith("/es");

const targetUrl = isSpanish
  ? BASE_URL
  : `${BASE_URL}es`;

const label = isSpanish ? "ESPAÑOL" : "ENGLISH";
---

<a
  href={targetUrl}
  aria-label="Change language"
  class="rounded-full border-3 border-black bg-white px-4 py-2 text-m font-bold text-black shadow-sm transition hover:scale-105 hover:bg-black hover:text-white"
>
  {label}
</a>