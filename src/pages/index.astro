---
import BaseLayout from "../layouts/BaseLayout.astro";

import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Projects from "../components/sections/Projects.astro";
import Experience from "../components/sections/Experience.astro";
import Achievements from "../components/sections/Achievements.astro";
import Certificates from "../components/sections/Certificates.astro";
import Blogs from "../components/sections/Blogs.astro";
import Contact from "../components/sections/Contact.astro";

import about from "../data/en/about.json";
import projects from "../data/en/projects.json";
import experience from "../data/en/experience.json";
import achievements from "../data/en/achievements.json";
import certificates from "../data/en/certificates.json";
import blogs from "../data/en/blogs.json";
import contact from "../data/en/contact.json"
import footer from "../data/en/footer.json";

const seo = {
	title: "Pablo Rojas | Backend Developer",
	description:
		"Backend Developer focused on scalable solutions with Python, JavaScript, Data Engineering and applied AI.",
	author: "Pablo Rojas",
	keywords: [
		"Pablo Rojas",
		"Backend Developer",
		"Python Developer",
		"JavaScript Developer",
		"Portfolio",
		"Data Engineering",
		"AI Engineering"
	],
	image: "https://pablo-rojas-dev.github.io/cover.jpg",
	url: "https://pablo-rojas-dev.github.io"
};
---

<BaseLayout
	lang="en"
	title={seo.title}
	description={seo.description}
	author={seo.author}
	keywords={seo.keywords}
	image={seo.image}
	baseUrl={seo.url}
	footer={footer}
>

	<Hero lang="en" />
	<About data={about} />
	<Projects data={projects} />
	<Experience data={experience} />
	<Achievements data={achievements} />
	<Certificates data={certificates} />
	<Blogs data={blogs} />
	<Contact data={contact} />

</BaseLayout>