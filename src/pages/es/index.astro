---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Hero from "../../components/sections/Hero.astro";
import About from "../../components/sections/About.astro";
import Projects from "../../components/sections/Projects.astro";
import Experience from "../../components/sections/Experience.astro";
import Achievements from "../../components/sections/Achievements.astro";
import Certificates from "../../components/sections/Certificates.astro";
import Blogs from "../../components/sections/Blogs.astro";
import Contact from "../../components/sections/Contact.astro";

import about from "../../data/es/about.json";
import projects from "../../data/es/projects.json";
import experience from "../../data/es/experience.json";
import achievements from "../../data/es/achievements.json";
import certificates from "../../data/es/certificates.json";
import blogs from "../../data/es/blogs.json";
import contact from "../../data/es/contact.json";
import footer from "../../data/es/footer.json";

const seo = {
    title: "Pablo Rojas | Desarrollador Web",
    description:
        "Estudiante de la lic. en informática enfocado en el desarrollador web.",
    author: "Pablo Rojas",
    keywords: [
        "Pablo Rojas",
        "Desarrollador Web",
        "Portafolio"
    ]
};
---

<BaseLayout
    lang="es"
    title={seo.title}
    description={seo.description}
    author={seo.author}
    keywords={seo.keywords}
    footer={footer}
>

    <Hero lang="es" />
    <About data={about} />
    <Projects data={projects} />
    <Experience data={experience} />
    <Achievements data={achievements} />
    <Certificates data={certificates} />
    <Blogs data={blogs} />
    <Contact data={contact} />

</BaseLayout>