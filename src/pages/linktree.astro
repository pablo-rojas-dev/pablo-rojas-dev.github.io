---
import BaseLayout from "../layouts/BaseLayout.astro";
import LinkTree from "../components/LinkTree.astro";

const seo = {
  title: "Pablo Rojas | Linktree",
  description: "Pablo Rojas - Linktree",
  author: "Pablo Rojas",
  keywords: [
    "Pablo Rojas",
    "Linktree",
    "Backend Developer",
    "Portfolio",
    "GitHub",
    "LinkedIn",
    "CV"
